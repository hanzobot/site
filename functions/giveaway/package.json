{
  "name": "giveaway-function",
  "version": "1.0.0",
  "description": "HTTP cloud function that upserts giveaway entries into a Google Sheet.",
  "type": "module",
  "main": "index.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "functions-framework --target=giveaway --port=8081",
    "deploy": "gcloud functions deploy giveaway --gen2 --runtime=nodejs20 --region=${REGION:-us-central1} --source=. --entry-point=giveaway --trigger-http --allow-unauthenticated --set-env-vars=SHEET_ID=${SHEET_ID},SHEET_NAME=${SHEET_NAME:-Entries},ALLOWED_ORIGINS=${ALLOWED_ORIGINS}"
  },
  "dependencies": {
    "@google-cloud/functions-framework": "^3.4.2",
    "googleapis": "^144.0.0"
  }
}
